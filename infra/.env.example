# =============================================================================
# Seller Cockpit — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your secrets.
# NEVER commit .env to git (it is .gitignored by default).
# =============================================================================

# ── Database ───────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme-strong-password
POSTGRES_DB=sellercockpit
POSTGRES_PORT=5432

# ── MinIO (S3-compatible object storage) ─────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme-strong-password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=seller-cockpit-media

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_PASSWORD=changeme-strong-password

# ── API Server ───────────────────────────────────────────────────────────
API_PORT=8080

# ── AI Providers (at least one required for real AI pipeline) ────────────
AI_MOCK_ENABLED=false
AI_PRIMARY_PROVIDER=openai
AI_FALLBACK_PROVIDER=anthropic

OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxx

# ── eBay Marketplace ───────────────────────────────────────────────────────
EBAY_API_BASE_URL=https://api.ebay.com
EBAY_AUTH_URL=https://auth.ebay.com
EBAY_CLIENT_ID=your-ebay-client-id
EBAY_CLIENT_SECRET=your-ebay-client-secret
EBAY_REDIRECT_URI=https://api.yourdomain.com/api/marketplaces/ebay/callback
EBAY_FINDING_APP_ID=your-ebay-finding-app-id

# ── Security ───────────────────────────────────────────────────────────────
# 64-character hex-encoded AES-256 key for token encryption.
# Generate: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# ── Firebase Auth ──────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id

# ── Production / Traefik ───────────────────────────────────────────────────
ACME_EMAIL=admin@yourdomain.com
API_HOST=api.yourdomain.com
MINIO_HOST=minio.yourdomain.com
TRAEFIK_DASHBOARD_HOST=traefik.yourdomain.com
TRAEFIK_AUTH_USERS=admin:$$apr1$$H6uskkkW$$IgXLP6ewTrSuBkTrqE8wj/  # htpasswd -nb admin password
TRAEFIK_LOG_LEVEL=INFO
CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ── Docker Image ───────────────────────────────────────────────────────────
# For production: use pre-built image from GHCR instead of local build
API_IMAGE=ghcr.io/jdev-bot/seller-cockpit-api:latest

# ── Logging ────────────────────────────────────────────────────────────────
QUARKUS_LOG_LEVEL=INFO
